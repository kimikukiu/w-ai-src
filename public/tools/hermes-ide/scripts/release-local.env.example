# Hermes IDE — Local Release Credentials
# Copy to release-local.env and fill in your values.
# This file is gitignored — never commit it.

# Updater signing key password (key file is read from ~/.tauri/hermes-ide.key)
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# Apple code signing identity (e.g. "Developer ID Application: Your Name (TEAM_ID)")
APPLE_SIGNING_IDENTITY=

# Apple notarization (required for macOS builds, skip with --skip-notarize)
APPLE_ID=
APPLE_ID_PASSWORD=
APPLE_TEAM_ID=
